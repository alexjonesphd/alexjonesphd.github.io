        "                .groupby(['perception', 'green', 'chain', 'draw'])\n",
        "                .agg(mu=('rating_mean', 'mean'))\n",
        "                .query('perception == \"feminine\"')\n",
        "                .unstack('green')\n",
        "                .droplevel(0, axis='columns')\n",
