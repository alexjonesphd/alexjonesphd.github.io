    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "# Estimate a Bayes Factor and plot\n",
        "prior = st.norm(0, 0.25)\n",
        "post = st.gaussian_kde(feminine_emm['difference'].values)\n",
        "\n",
